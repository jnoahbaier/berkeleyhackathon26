{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/surfaces/**",
              "ui_kits/babel-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Schibsted Grotesk|Newsreader|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Schibsted Grotesk, Newsreader, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|seat|src|size|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, seat, src, size, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GuildMember'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|seat|src|key|ref|className|style|children)$/]",
        "message": "<GuildMember> doesn't accept that prop. Declared props: name, seat, src."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|brand|lit|success|danger|night)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'brand' | 'lit' | 'success' | 'danger' | 'night'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|full|disabled|iconLeft|iconRight|onNight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, full, disabled, iconLeft, iconRight, onNight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevation|pad|onNight|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: elevation, pad, onNight, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:flat|sm|md|lg)$/]",
        "message": "<Card> elevation must be one of 'flat' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Choice'] > JSXAttribute > JSXIdentifier[name!=/^(?:letter|selected|flavor|meta|onClick|style|children|key|ref|className|style|children)$/]",
        "message": "<Choice> doesn't accept that prop. Declared props: letter, selected, flavor, meta, onClick, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Choice'] > JSXAttribute[name.name='flavor'] > Literal[value!=/^(?:default|betrayal)$/]",
        "message": "<Choice> flavor must be one of 'default' | 'betrayal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GuildDotMember'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|seat|done|key|ref|className|style|children)$/]",
        "message": "<GuildDotMember> doesn't accept that prop. Declared props: name, seat, done."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|variant|label|onNight|disabled|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, variant, label, onNight, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:glass|solid|brand|plain)$/]",
        "message": "<IconButton> variant must be one of 'glass' | 'solid' | 'brand' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|label|type|icon|onNight|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, label, type, icon, onNight."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressTrack'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|total|label|onNight|style|key|ref|className|style|children)$/]",
        "message": "<ProgressTrack> doesn't accept that prop. Declared props: value, total, label, onNight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|onNight|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, onChange, onNight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|onClose|onNight|children|key|ref|className|style|children)$/]",
        "message": "<Sheet> doesn't accept that prop. Declared props: title, onClose, onNight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|onChange|suffix|style|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: value, min, max, onChange, suffix, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryCover'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|author|genre|src|size|selected|onClick|key|ref|className|style|children)$/]",
        "message": "<StoryCover> doesn't accept that prop. Declared props: title, author, genre, src, size, selected, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryCover'] > JSXAttribute[name.name='genre'] > Literal[value!=/^(?:medieval|scifi|noir|cosy|horror|myth)$/]",
        "message": "<StoryCover> genre must be one of 'medieval' | 'scifi' | 'noir' | 'cosy' | 'horror' | 'myth'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryCover'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StoryCover> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|onClick|icon|style|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: selected, onClick, icon, style, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
